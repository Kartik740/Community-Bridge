rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Organisations — authenticated users can read all orgs (needed for NGO selection in register)
    match /organisations/{orgId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == orgId;
    }

    // Surveys — any authenticated user can read (volunteers need to fetch by code)
    match /surveys/{surveyId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == resource.data.orgId;
    }

    // Responses — authenticated volunteers can create, org owner can read/update
    match /responses/{responseId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null;
    }

    // Volunteers — any authenticated user can read, volunteer can write own profile
    match /volunteers/{volunteerId} {
      allow read: if request.auth != null;
      // Org admins can create volunteer docs on approval; volunteers update their own
      allow write: if request.auth != null;
    }

    // Volunteer Requests — volunteer creates own; org reads all for their org; org updates status
    match /volunteerRequests/{requestId} {
      // Volunteer can create OR update their own request (requestId == their UID)
      // This covers initial registration and retries after partial failures
      allow create, update: if request.auth != null && request.auth.uid == requestId;
      // Org admin can also update status (approve/reject)
      allow update: if request.auth != null
        && resource != null
        && request.auth.uid == resource.data.orgId;
      // Volunteer can read their own request (for status polling)
      allow read: if request.auth != null
        && (request.auth.uid == requestId
            || (resource != null && request.auth.uid == resource.data.orgId));
    }

    // Tasks — all authenticated users can read, volunteers can update own task status
    match /tasks/{taskId} {
      allow read: if request.auth != null;
      // Volunteers can update status fields only
      allow update: if request.auth != null
        && request.auth.uid == resource.data.assignedVolunteerId;
      allow create, delete: if false; // only backend admin SDK
    }

    // Alerts — volunteer can read own alerts
    match /alerts/{alertId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.volunteerId;
      allow write: if false; // only backend writes
    }
  }
}
